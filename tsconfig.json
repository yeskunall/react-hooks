{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "esModuleInterop": true,
    "jsx": "react",
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true
  }
}
